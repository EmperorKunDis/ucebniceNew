# Production Environment Variables
# Copy this file to .env.production and fill in the values

# Database - PostgreSQL in Kubernetes
DATABASE_URL="postgresql://ucebnice_user:STRONG_PASSWORD_HERE@ucebnice-postgres:5432/ucebnice_db"

# NextAuth Configuration
NEXTAUTH_URL="https://ucebnice.praut.cz"
NEXTAUTH_SECRET="GENERATE_WITH_openssl_rand_base64_32"

# Application URL
NEXT_PUBLIC_APP_URL="https://ucebnice.praut.cz"

# Node Environment
NODE_ENV="production"

# Optional: Google OAuth (if using)
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Optional: Redis (if using)
# UPSTASH_REDIS_REST_URL="your-upstash-url"
# UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# Optional: Sentry (if using)
# NEXT_PUBLIC_SENTRY_DSN="your-sentry-dsn"

# Important Security Notes:
# 1. Never commit .env.production to Git
# 2. Use strong passwords (minimum 32 characters)
# 3. Generate NEXTAUTH_SECRET with: openssl rand -base64 32
# 4. In Kubernetes, these should be stored as Secrets, not environment files
