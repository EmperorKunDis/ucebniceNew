# 🗄️ Database Configuration
# PostgreSQL (výchozí):
DATABASE_URL="postgresql://ucebnice_user:changeme123@localhost:5433/ucebnice_db"

# Nebo pro jiný server:
# DATABASE_URL="postgresql://ucebnice_user:password@your-server-ip:5432/ucebnice_db"

# Pro Docker PostgreSQL:
POSTGRES_PASSWORD="changeme123"

# 🔐 NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-secret-with: openssl rand -base64 32"

# 🌐 Application URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 🔧 Environment
NODE_ENV="development"

# 📊 Optional: Rate Limiting (Upstash Redis)
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# 📈 Optional: Monitoring (Sentry)
# SENTRY_DSN=""
# SENTRY_AUTH_TOKEN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""

# 🔐 Google OAuth (pro přihlášení přes Google)
# Viz docs/GOOGLE_OAUTH_SETUP.md pro návod
# GOOGLE_CLIENT_ID="xxxxx.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="GOCSPX-xxxxx"

# 🤖 Gemini AI (pro kontrolu projektů)
# Získej na: https://makersuite.google.com/app/apikey
# GEMINI_API_KEY="AIzaSy..."

# 📧 Email (pro ověřovací emaily)
# Resend: https://resend.com (free tier: 100 emails/day)
# RESEND_API_KEY="re_..."
# EMAIL_FROM="Učebnice AI <noreply@yourdomain.com>"
