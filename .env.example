# 🗄️ Database Configuration
# PostgreSQL (výchozí):
DATABASE_URL="postgresql://ucebnice_user:changeme123@localhost:5432/ucebnice_db"

# Nebo pro jiný server:
# DATABASE_URL="postgresql://ucebnice_user:password@your-server-ip:5432/ucebnice_db"

# Pro Docker PostgreSQL:
POSTGRES_PASSWORD="changeme123"

# 🔐 NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-secret-with: openssl rand -base64 32"

# 🌐 Application URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 🔧 Environment
NODE_ENV="development"

# 📊 Optional: Rate Limiting (Upstash Redis)
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# 📈 Optional: Monitoring (Sentry)
# SENTRY_DSN=""
# SENTRY_AUTH_TOKEN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""
