#!/bin/sh

message_file="$1"
message="$(cat "$message_file")"

case "$message" in
  Merge\ *|Revert\ *|fixup!\ *|squash!\ *)
    exit 0
    ;;
esac

if ! printf '%s' "$message" | grep -Eq '^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-zA-Z0-9._/-]+\))?!?: .+'; then
  echo "Commit message must follow Conventional Commits, for example:"
  echo "  feat(api): add project review metadata"
  exit 1
fi
