// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?   // Pro credentials login
  username      String?   @unique

  // Game-like attributes
  xp            Int       @default(0)
  level         Int       @default(1)
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)

  // Metadata
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  completedLessons CompletedLesson[]
  achievements  UserAchievement[]
  lessonProgress LessonProgress[]
  cognitiveGlitches CognitiveGlitchAttempt[]
  chapterCompletions ChapterCompletion[]
  questionAnswers QuestionAnswer[]
  projectSubmissions ProjectSubmission[]
  moduleTestAttempts ModuleTestAttempt[]

  // Indexes for performance
  @@index([xp])
  @@index([level])
  @@index([createdAt])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Application specific models

model Lesson {
  id          String   @id @default(cuid())
  chapterId   String   // Maps to chapter.id from chapters.ts
  title       String
  description String?
  xpReward    Int      @default(100)
  difficulty  String   // beginner, intermediate, advanced
  order       Int      // Order within the course

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  completedBy CompletedLesson[]
  progress    LessonProgress[]

  // Indexes for performance
  @@index([chapterId])
  @@index([difficulty])
  @@index([order])
}

model CompletedLesson {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  completedAt DateTime @default(now())
  xpEarned    Int

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@index([completedAt])
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  progress    Int      @default(0) // 0-100
  lastUpdated DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@index([lastUpdated])
}

model Achievement {
  id          String   @id @default(cuid())
  badgeId     String   @unique // Maps to BADGES constant
  name        String
  description String
  icon        String
  xpReward    Int
  rarity      String   // common, uncommon, rare, epic, legendary
  
  createdAt   DateTime @default(now())
  
  users       UserAchievement[]
}

model UserAchievement {
  id           String   @id @default(cuid())
  userId       String
  achievementId String
  unlockedAt   DateTime @default(now())

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement  Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
  @@index([unlockedAt])
}

model CognitiveGlitchAttempt {
  id          String   @id @default(cuid())
  userId      String
  challengeId String   // Maps to glitch challenge id
  correct     Boolean
  hintUsed    Boolean  @default(false)
  timeElapsed Int      // in seconds
  xpEarned    Int
  attemptedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([challengeId])
  @@index([attemptedAt])
}

// Chapter completion tracking with 3-star system
model ChapterCompletion {
  id          String   @id @default(cuid())
  userId      String
  chapterId   String   // Maps to chapter.id from chapters.ts
  stars       Int      @default(1) // 1=completed, 2=all questions, 3=project submitted
  completedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@index([userId])
  @@index([chapterId])
  @@index([stars])
}

// Question answers for gamification
model QuestionAnswer {
  id         String   @id @default(cuid())
  userId     String
  chapterId  String   // Maps to chapter.id from chapters.ts
  questionId String   // Question identifier within the chapter
  answer     String   // User's answer
  correct    Boolean  // Whether the answer was correct
  xpEarned   Int      @default(0)
  answeredAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId, questionId])
  @@index([userId])
  @@index([chapterId])
  @@index([answeredAt])
}

// Project submissions
model ProjectSubmission {
  id          String   @id @default(cuid())
  userId      String
  chapterId   String   // Maps to chapter.id from chapters.ts
  projectUrl  String   // GitHub URL, Colab notebook URL, etc.
  description String?
  xpEarned    Int      @default(0)
  submittedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@index([userId])
  @@index([chapterId])
  @@index([submittedAt])
}

// Module test attempts (tests after every 10 chapters)
model ModuleTestAttempt {
  id              String   @id @default(cuid())
  userId          String
  moduleNumber    Int      // 1 for chapters 1-10, 2 for 11-20, etc.
  score           Int      // Number of correct answers out of 10
  totalQuestions  Int      @default(10)
  timeElapsed     Int      // Time in seconds
  attemptNumber   Int      // How many times user attempted this module test
  completed       Boolean  @default(false)
  abandoned       Boolean  @default(false) // User gave up
  xpEarned        Int      @default(0)
  moduleStars     Int      @default(0) // Stars earned for the module (0-3)
  createdAt       DateTime @default(now())
  completedAt     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([moduleNumber])
  @@index([score])
  @@index([createdAt])
  @@index([userId, moduleNumber])
}