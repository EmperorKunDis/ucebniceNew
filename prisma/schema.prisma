// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres", "postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth models
model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @db.Uuid
  type              String  @db.VarChar(100)
  provider          String  @db.VarChar(100)
  providerAccountId String  @db.VarChar(255)
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String? @db.VarChar(100)
  scope             String? @db.Text
  id_token          String? @db.Text
  session_state     String? @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @db.VarChar(255)
  userId       String   @db.Uuid
  expires      DateTime @db.Timestamptz
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String?   @unique @db.VarChar(255)
  emailVerified DateTime? @db.Timestamptz
  name          String?   @db.VarChar(255)
  image         String?   @db.Text
  password      String?   @db.VarChar(255)
  username      String?   @unique @db.VarChar(100)

  // Game-like attributes
  xp            Int @default(0)
  level         Int @default(1)
  currentStreak Int @default(0)
  longestStreak Int @default(0)

  // Metadata
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  // Relations
  accounts           Account[]
  sessions           Session[]
  completedLessons   CompletedLesson[]
  achievements       UserAchievement[]
  lessonProgress     LessonProgress[]
  cognitiveGlitches  CognitiveGlitchAttempt[]
  chapterCompletions ChapterCompletion[]
  questionAnswers    QuestionAnswer[]
  projectSubmissions ProjectSubmission[]
  moduleTestAttempts ModuleTestAttempt[]

  // Indexes for performance
  @@index([xp])
  @@index([level])
  @@index([email])
  @@index([createdAt])
}

model VerificationToken {
  identifier String   @db.VarChar(255)
  token      String   @unique @db.VarChar(255)
  expires    DateTime @db.Timestamptz

  @@unique([identifier, token])
}

// Application specific models

model Lesson {
  id          String  @id @default(uuid()) @db.Uuid
  chapterId   String  @unique @db.VarChar(10)
  title       String  @db.VarChar(255)
  description String? @db.Text
  xpReward    Int     @default(100)
  difficulty  String  @db.VarChar(50)
  order       Int

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  completedBy CompletedLesson[]
  progress    LessonProgress[]

  // Indexes for performance
  @@index([difficulty])
  @@index([order])
}

model CompletedLesson {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  lessonId    String   @db.Uuid
  completedAt DateTime @default(now()) @db.Timestamptz
  xpEarned    Int

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@index([completedAt])
}

model LessonProgress {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  lessonId    String   @db.Uuid
  progress    Int      @default(0)
  lastUpdated DateTime @default(now()) @db.Timestamptz

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@index([lastUpdated])
}

model Achievement {
  id          String @id @default(uuid()) @db.Uuid
  badgeId     String @unique @db.VarChar(100)
  name        String @db.VarChar(255)
  description String @db.Text
  icon        String @db.VarChar(255)
  xpReward    Int
  rarity      String @db.VarChar(50)

  createdAt DateTime @default(now()) @db.Timestamptz

  users UserAchievement[]

  @@index([badgeId])
  @@index([rarity])
}

model UserAchievement {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  achievementId String   @db.Uuid
  unlockedAt    DateTime @default(now()) @db.Timestamptz

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
  @@index([unlockedAt])
}

model CognitiveGlitchAttempt {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  challengeId String   @db.VarChar(100)
  correct     Boolean
  hintUsed    Boolean  @default(false)
  timeElapsed Int
  xpEarned    Int
  attemptedAt DateTime @default(now()) @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([challengeId])
  @@index([attemptedAt])
}

// Chapter completion tracking with 3-star system
// Each star represents independent achievement:
// Star 1: Chapter completed
// Star 2: Questions answered correctly
// Star 3: Project submitted
model ChapterCompletion {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @db.Uuid
  chapterId          String   @db.VarChar(10)
  completedChapter   Boolean  @default(false)
  answeredQuestions  Boolean  @default(false)
  submittedProject   Boolean  @default(false)
  completedAt        DateTime @default(now()) @db.Timestamptz
  updatedAt          DateTime @updatedAt @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@index([userId])
  @@index([chapterId])
  @@index([completedAt])
}

// Question answers for gamification
model QuestionAnswer {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  chapterId  String   @db.VarChar(10)
  questionId String   @db.VarChar(100)
  answer     String   @db.Text
  correct    Boolean
  xpEarned   Int      @default(0)
  answeredAt DateTime @default(now()) @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId, questionId])
  @@index([userId])
  @@index([chapterId])
  @@index([answeredAt])
}

// Project submissions
model ProjectSubmission {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  chapterId   String   @db.VarChar(10)
  projectUrl  String   @db.Text
  description String?  @db.Text
  xpEarned    Int      @default(0)
  submittedAt DateTime @default(now()) @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@index([userId])
  @@index([chapterId])
  @@index([submittedAt])
}

// Module test attempts (tests after every 10 chapters)
model ModuleTestAttempt {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @db.Uuid
  moduleNumber   Int
  score          Int
  totalQuestions Int       @default(10)
  timeElapsed    Int
  attemptNumber  Int
  completed      Boolean   @default(false)
  abandoned      Boolean   @default(false)
  xpEarned       Int       @default(0)
  moduleStars    Int       @default(0)
  createdAt      DateTime  @default(now()) @db.Timestamptz
  completedAt    DateTime? @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([moduleNumber])
  @@index([score])
  @@index([createdAt])
  @@index([userId, moduleNumber])
}
