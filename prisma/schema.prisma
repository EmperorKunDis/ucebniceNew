// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// NextAuth models
model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String    @id @default(uuid())
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?
  username      String?   @unique

  // Game-like attributes
  xp            Int @default(0)
  level         Int @default(1)
  currentStreak Int @default(0)
  longestStreak Int @default(0)

  // Admin access
  isAdmin Boolean @default(false)

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  accounts           Account[]
  sessions           Session[]
  completedChapters  CompletedChapter[]
  achievements       UserAchievement[]
  chapterProgress    ChapterProgress[]
  cognitiveGlitches  CognitiveGlitchAttempt[]
  chapterCompletions ChapterCompletion[]
  questionAnswers    QuestionAnswer[]
  projectSubmissions ProjectSubmission[]
  moduleTestAttempts ModuleTestAttempt[]

  // Arena relations
  teamMemberships TeamMember[]
  graduateProfile GraduateProfile?

  // Indexes for performance
  @@index([xp])
  @@index([level])
  @@index([email])
  @@index([createdAt])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Application specific models

model Chapter {
  id          String  @id @default(uuid())
  chapterId   String  @unique
  title       String
  description String?
  xpReward    Int     @default(100)
  difficulty  String
  order       Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questions   Question[]

  completedBy CompletedChapter[]
  progress    ChapterProgress[]

  // Indexes for performance
  @@index([difficulty])
  @@index([order])
}


model CompletedChapter {
  id          String   @id @default(uuid())
  userId      String
  chapterId   String
  completedAt DateTime @default(now())
  xpEarned    Int

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@index([userId])
  @@index([chapterId])
  @@index([completedAt])
}

model ChapterProgress {
  id          String   @id @default(uuid())
  userId      String
  chapterId   String
  progress    Int      @default(0)
  lastUpdated DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@index([userId])
  @@index([chapterId])
  @@index([lastUpdated])
}

model Achievement {
  id          String @id @default(uuid())
  badgeId     String @unique
  name        String
  description String
  icon        String
  xpReward    Int
  rarity      String

  createdAt DateTime @default(now())

  users UserAchievement[]

  @@index([badgeId])
  @@index([rarity])
}

model UserAchievement {
  id            String   @id @default(uuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
  @@index([unlockedAt])
}

model CognitiveGlitchAttempt {
  id          String   @id @default(uuid())
  userId      String
  challengeId String
  correct     Boolean
  hintUsed    Boolean  @default(false)
  timeElapsed Int
  xpEarned    Int
  attemptedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([challengeId])
  @@index([attemptedAt])
}

// Chapter completion tracking with 3-star system
// Each star represents independent achievement:
// Star 1: Chapter completed
// Star 2: Questions answered correctly
// Star 3: Project submitted
model ChapterCompletion {
  id                 String   @id @default(uuid())
  userId             String
  chapterId          String
  completedChapter   Boolean  @default(false)
  answeredQuestions  Boolean  @default(false)
  submittedProject   Boolean  @default(false)
  completedAt        DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@index([userId])
  @@index([chapterId])
  @@index([completedAt])
}

// Question answers for gamification
model QuestionAnswer {
  id         String   @id @default(uuid())
  userId     String
  chapterId  String
  questionId String
  answer     String
  correct    Boolean
  xpEarned   Int      @default(0)
  answeredAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId, questionId])
  @@index([userId])
  @@index([chapterId])
  @@index([answeredAt])
}

// Project submissions
model ProjectSubmission {
  id          String   @id @default(uuid())
  userId      String
  chapterId   String
  projectUrl  String
  description String?
  xpEarned    Int      @default(0)
  submittedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@index([userId])
  @@index([chapterId])
  @@index([submittedAt])
}

// Module test attempts (tests after every 10 chapters)
model ModuleTestAttempt {
  id             String    @id @default(uuid())
  userId         String
  moduleNumber   Int
  score          Int
  totalQuestions Int       @default(10)
  timeElapsed    Int
  attemptNumber  Int
  completed      Boolean   @default(false)
  abandoned      Boolean   @default(false)
  xpEarned       Int       @default(0)
  moduleStars    Int       @default(0)
  createdAt      DateTime  @default(now())
  completedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([moduleNumber])
  @@index([score])
  @@index([createdAt])
  @@index([userId, moduleNumber])
}

// Questions for each chapter (comprehensive model)
model Question {
  id             String   @id @default(uuid())
  chapterId      String
  questionNumber Int      // 1, 2, 3 for ordering
  questionText   String
  options        Json     // Array of strings: ["option1", "option2", "option3"]
  correctAnswer  Int      // Index of correct option (0, 1, 2, etc.)
  explanation    String?  // Optional explanation
  xpReward       Int      @default(10)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([chapterId, questionNumber])
  @@index([chapterId])
}

// ========================================
// ARENA SYSTEM MODELS
// ========================================

// Hackathon - main competition events
model Hackathon {
  id                   String   @id @default(uuid())
  title                String
  description          String
  theme                String
  startDate            DateTime
  endDate              DateTime
  status               String   @default("upcoming") // upcoming, active, completed
  maxTeamSize          Int      @default(4)
  registrationDeadline DateTime
  bannerImage          String?
  prizes               Json     // [{place, title, description, value}]
  judges               Json     // [{id, name, title, company, bio, avatar?}]
  sponsors             Json     @default("[]") // ["Sponsor1", "Sponsor2"]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  teams                Team[]
  projects             HackathonProject[]

  @@index([status])
  @@index([startDate])
}

// Team - hackathon participant teams
model Team {
  id          String             @id @default(uuid())
  name        String
  hackathonId String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  hackathon   Hackathon          @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  members     TeamMember[]
  project     HackathonProject?

  @@index([hackathonId])
}

// TeamMember - user membership in teams
model TeamMember {
  id       String   @id @default(uuid())
  teamId   String
  userId   String
  role     String   @default("member") // leader, member
  skills   Json     @default("[]")
  joinedAt DateTime @default(now())
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

// HackathonProject - submitted project for hackathon
model HackathonProject {
  id           String    @id @default(uuid())
  teamId       String    @unique
  hackathonId  String
  title        String
  description  String
  githubUrl    String
  demoUrl      String?
  videoUrl     String?
  screenshots  Json      @default("[]")
  technologies Json      @default("[]")
  submittedAt  DateTime  @default(now())
  score        Int?
  placement    Int?
  feedback     Json?     // [{judgeId, score, comments, categories}]
  team         Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  hackathon    Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)

  @@index([hackathonId])
}

// GraduateProfile - alumni showcase profile
model GraduateProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  bio            String?
  graduatedAt    DateTime @default(now())
  certificateId  String   @unique
  skills         Json     @default("[]")
  portfolio      Json     @default("[]") // [{id, title, description, url, type, technologies}]
  linkedIn       String?
  github         String?
  website        String?
  lookingForWork Boolean  @default(false)
  preferredRoles Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lookingForWork])
  @@index([graduatedAt])
}